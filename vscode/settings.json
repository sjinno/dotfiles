{
  "workbench.startupEditor": "newUntitledFile",
  "rust-client.channel": "stable",
  "editor.formatOnSave": true,
  "[rust]": {},
  "window.menuBarVisibility": "toggle",
  "editor.minimap.enabled": false,
  "hediet.vscode-drawio.theme": "dark",
  "files.associations": {
    "*.drawio": "javascript",
    "*.js": "javascript",
    "*.css": "scss"
  },
  "hediet.vscode-drawio.local-storage": {
    ".drawio-config": {
      "language": "",
      "customFonts": [],
      "libraries": "general;uml;er;bpmn;flowchart;basic;arrows2",
      "customLibraries": ["L.scratchpad"],
      "plugins": [],
      "recentColors": [],
      "formatWidth": "240",
      "createTarget": false,
      "pageFormat": {
        "x": 0,
        "y": 0,
        "width": 850,
        "height": 1100
      },
      "search": true,
      "showStartScreen": true,
      "gridColor": "#d0d0d0",
      "darkGridColor": "#6e6e6e",
      "autosave": true,
      "resizeImages": null,
      "openCounter": 0,
      "version": 18,
      "unit": 1,
      "isRulerOn": false,
      "ui": ""
    }
  },
  "rust.build_command": "",
  "launch": {},
  "[javascript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[javascriptreact]": {},
  // "editor.fontLigatures": true,
  "[json]": {},
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.fontFamily": "Droid Sans Mono",
  "diffEditor.ignoreTrimWhitespace": false,
  // "editor.letterSpacing": 0,
  "editor.lineHeight": 18,
  // "editor.codeActionsOnSave": null,
  "editor.fontLigatures": "'ss01",
  "http.proxyAuthorization": null,
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "name": "comment",
        "scope": ["comment"],
        "settings": {
          // "fontStyle": "italic"
          // "foreground": "#768948"
          // "foreground": "#7FB069"
          // "foreground": "#C5D86D"
        }
      },
      {
        "name": "Keyword Storage",
        "scope": [
          // "keyword",
          // "storage",
          // "keyword.control",
          "storage.type.function.rust",
          "storage.type.function.python",
          "storage.type.function.js"
          // "storage.type.function.rust"
        ],
        "settings": {
          // "fontStyle": "italic"
          // "foreground": "#f95738"
          // "foreground": "#ff9100" //CITY LIGHTS
        }
      },
      // {
      //   "name": "[PYTHON] - Fuction ",
      //   "scope": "storage.type.function.python",
      //   "settings": {
          // "foreground": "#f95738"
      //   },
      {
        "name": "Entity",
        "scope": [
          // "entity.name.type.class", //class names
          // "entity.other.attribute-name",
          // "entity.name.method",
          // "entity.name.tag"
        ],
        "settings": {
          // "fontStyle": "italic"
          // "foreground": "#f95738" //CITY LIGHTS
        }
      },
      // {
      //   "name": "Variable",
      //   "scope": [
      //     "variable.language",
      //     "meta.paragraph.markdown",
      //     "support.type.property-name.json",
      //     "string.other.link.title.markdown"
      //   ],
      //   "settings": {
      //     "fontStyle": "italic"
      //   }
      // },
      {
        "name": "Markdown",
        "scope": [
          "meta.paragraph.markdown",
          "string.other.link.title.markdown",
          "markup.underline.link.markdown"
        ],
        "settings": {
          "fontStyle": "italic"
        }
      }
      // {
      //   "name": "Json",
      //   "scope": ["support.type.property-name.json"],
      //   "settings": {
      //     "fontStyle": "italic"
      //   }
      // }
    ]
  },
  "editor.renderWhitespace": "all",
  // "editor.codeActionsOnSave": null,
  "workbench.colorCustomizations": {
    // "statusBar.background": "#3d59ab",
    // "statusBar.noFolderBackground": "#3d59ab",
    "statusBar.background": "#33312e",
    // "statusBar.noFolderBackground": "#4058f7",
    "statusBar.debuggingBackground": "#33312e",
    "statusBar.foreground": "#ffffff",
    // "editorWhitespace.foreground": "#b5838d",
    "editorWhitespace.foreground": "#a3b18a", // Laurel green
    // "editorWhitespace.foreground": "#588157", // Fern green
    // "editorWhitespace.foreground": "#aa4465", // Irresistible red
    // "editorWhitespace.foreground": "#6d6875" //CITY LIGHTS
    // "editor.background": "#f0efeb", // GITHUB PLUS
    // "editor.background": "#f4f1de", // GITHUB PLUS
    "editor.background": "#f3f0df", // GITHUB PLUS
    // "editor.background": "#f4faff", // VIRDIGRIS LIGHT alice blue
    "sideBar.background": "#f0f0f0", // SIDE BAR
    "activityBar.background": "#f6f8fa", // ACTIVITY BARD
    "activityBar.foreground": "#1b1f23",
    "editorGroupHeader.tabsBackground": "#f0f0f0", // TABS BACKGROUND
    "tab.inactiveBackground": "#f0f0f0",
    "tab.activeBackground": "#fafbfc",
    "scrollbarSlider.background": "#1b1f23",
  },
  "window.zoomLevel": 0,
  "editor.suggestSelection": "first",
  "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
  "workbench.iconTheme": "file-icons",
  "editor.fontSize": 12,
  "workbench.colorTheme": "GitHub Plus",
  "editor.fontFamily": "'Liberation Mono', 'Droid Sans Mono', 'monospace', monospace, 'Droid Sans Fallback'",
  "debug.allowBreakpointsEverywhere": true,
  "C_Cpp.updateChannel": "Insiders",
  "rust-analyzer.inlayHints.maxLength": 6,
  "rust-analyzer.inlayHints.enable": false,
  "workbench.activityBar.visible": true,
  "editor.scrollbar.horizontalScrollbarSize": 0,
  "editor.scrollbar.verticalScrollbarSize": 1,
  "window.title": "${dirty}${activeEditorShort}",
  "latex-workshop.latex.autoBuild.run": "never"
}
